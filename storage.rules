rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Property media — any authenticated user may upload:
    //  • images  (≤ 15MB)
    //  • videos  (≤ 80MB) — property tour clips
    //  • PDFs    (≤ 15MB) — legal documents (contract / registry)
    // Object names are timestamp+random, so clobbering someone else's file is
    // effectively impossible.
    match /properties/{fileName} {
      allow read: if true;
      allow create, update: if isAuthenticated() && (
                     (request.resource.contentType.matches('image/.*') && request.resource.size < 15 * 1024 * 1024) ||
                     (request.resource.contentType.matches('video/.*') && request.resource.size < 80 * 1024 * 1024) ||
                     (request.resource.contentType == 'application/pdf' && request.resource.size < 15 * 1024 * 1024)
                   );
      allow delete: if isAuthenticated();
    }

    // Match user documents
    match /user_documents/{userId}/{fileName} {
      // Only the owner can read or write their own documents
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
                   // Limit file size to 5MB
                   && request.resource.size < 5 * 1024 * 1024
                   // Only allow specific content types (PDFs, Images)
                   && request.resource.contentType.matches('application/pdf|image/.*');
      allow delete: if isOwner(userId);
    }
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
